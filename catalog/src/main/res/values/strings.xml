<?xml version="1.0" encoding="utf-8"?>
<!--
    User-visible strings for the Knotwork design-system catalog.

    Naming convention: `knotwork_<surface>_<role>_<intent>` so a global text search
    locates every translation site at once. Phase 21 introduces the catalog's
    first localised surface (chat + console); existing components keep their
    inline labels until Phase 21 / Task 11 (a11y + RC) sweeps them in.

    Author guidance: never inline a user-visible string in a new component —
    add it here first, then reference it via `stringResource(R.string.…)`.
-->
<resources xmlns:tools="http://schemas.android.com/tools">

