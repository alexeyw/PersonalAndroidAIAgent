<?xml version="1.0" encoding="utf-8"?>
<!--
    User-visible strings for the Knotwork design-system catalog.

    Naming convention: `knotwork_<surface>_<role>_<intent>` so a global text search
    locates every translation site at once. Phase 21 introduces the catalog's
    first localised surface (chat + console); existing components keep their
    inline labels until Phase 21 / Task 11 (a11y + RC) sweeps them in.

    Author guidance: never inline a user-visible string in a new component —
    add it here first, then reference it via `stringResource(R.string.…)`.
-->
<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- ============ ChatMessage ============ -->

    <!-- Trailing status glyph contentDescription when a message is in flight. -->
    <string name="knotwork_chat_message_status_pending">Sending</string>
    <!-- Trailing status glyph contentDescription when a message has been delivered. -->
    <string name="knotwork_chat_message_status_sent">Sent</string>
    <!-- Trailing status glyph contentDescription when delivery failed. -->
    <string name="knotwork_chat_message_status_failed">Failed to send</string>

    <!-- Long-press context menu item labels (Copy / Re-run / Rate). -->
    <string name="knotwork_chat_message_action_copy">Copy</string>
    <string name="knotwork_chat_message_action_rerun">Re-run</string>
    <string name="knotwork_chat_message_action_rate">Rate</string>

    <!-- Retry button on the inline ChatContent.Error tile. -->
    <string name="knotwork_chat_message_error_retry">Retry</string>

    <!-- Fallback label rendered next to a centred ChatRole.System message
         whose content is not a Text / Markdown / Error variant. -->
    <string name="knotwork_chat_message_system_default">System update</string>

    <!-- Suffix appended after the tool-name in a ToolCall tile when the tool is running. -->
    <string name="knotwork_chat_message_tool_running">→ running…</string>
    <!-- Default success suffix when the tool returns no preview. -->
    <string name="knotwork_chat_message_tool_ok">→ OK</string>
    <!-- Default failure suffix when the tool returns no error preview. -->
    <string name="knotwork_chat_message_tool_error">→ error</string>
    <!-- Arrow-prefix template for ToolCall result lines: "→ %1$s". -->
    <string name="knotwork_chat_message_tool_arrow">→ %1$s</string>

    <!-- Token-count suffix in the bubble footer (e.g. "42 tok"). "%1$d" is the count.
         `tok` is an invariant abbreviation in every locale we currently ship; the
         pluralisation check fires a false positive here. -->
    <string name="knotwork_chat_message_token_count" tools:ignore="PluralsCandidate">%1$d tok</string>

    <!-- ============ HitlConfirmationCard ============ -->

    <!-- Reject CTA — destructive secondary button on every variant. -->
    <string name="knotwork_hitl_action_reject">Reject</string>
    <!-- Allow-once primary CTA — labelled identically for all risk tiers. -->
    <string name="knotwork_hitl_action_allow_once">Allow once</string>
    <!-- Always-allow text button — Sensitive variant only. -->
    <string name="knotwork_hitl_action_always_allow">Always allow</string>

    <!-- Placeholder for the destructive type-confirm OutlinedTextField. The "%1$s" -->
    <!-- token is replaced with HitlConfirmationState.DESTRUCTIVE_CONFIRM_WORD ("yes"). -->
    <string name="knotwork_hitl_typed_confirm_placeholder">Type \"%1$s\" to confirm</string>

    <!-- ContentDescription for the JSON-args expand/collapse chevron. -->
    <string name="knotwork_hitl_args_expand">Expand arguments</string>
    <string name="knotwork_hitl_args_collapse">Collapse arguments</string>

    <!-- ============ ClarificationCard ============ -->

    <!-- Default placeholder for the free-form clarification field if the caller -->
    <!-- does not override `ClarificationCardModel.freeformPlaceholder`. -->
    <string name="knotwork_clarification_freeform_default">Your answer…</string>

    <!-- ContentDescription for the trailing send-icon-button. -->
    <string name="knotwork_clarification_send">Send reply</string>

    <!-- Replied-summary line. "%1$s" is the user's submitted answer. -->
    <string name="knotwork_clarification_replied">Replied: %1$s</string>

    <!-- ============ ChatComposer ============ -->

    <!-- Placeholder for the multiline composer input. -->
    <string name="knotwork_composer_placeholder">Message…</string>
    <!-- ContentDescription for the leading attach-file icon button. -->
    <string name="knotwork_composer_attach">Attach file</string>
    <!-- ContentDescription for the leading voice-input icon button. -->
    <string name="knotwork_composer_voice">Start voice input</string>
    <!-- ContentDescription for the trailing send button (Idle / Error states). -->
    <string name="knotwork_composer_send">Send message</string>
    <!-- ContentDescription for the trailing stop button (Generating state). -->
    <string name="knotwork_composer_stop">Stop generating</string>

    <!-- ============ ConsolePane ============ -->

    <!-- ContentDescription for the Search header action. -->
    <string name="knotwork_console_action_search">Search log</string>
