<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!--
        EXECUTE_APP_FUNCTIONS is required for the probe's MainActivity to call the agent's
        `search_tool` AppFunction back across processes. The matching declaration in
        :app already exposes the function; this side only consumes it.
    -->
    <uses-permission android:name="android.permission.EXECUTE_APP_FUNCTIONS" />

    <!--
        Phase 20 / Task 6/7: the probe needs `canPackageQuery` access to the agent app
        so `AppFunctionManager.observeAppFunctions` can resolve the agent's
        `search_tool` metadata when the user taps the probe's invoke button.
    -->
    <queries>
        <package android:name="app.knotwork.android" />
    </queries>

    <application
        android:label="@string/probe_app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.ToolsProbe">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/probe_app_name"
            android:theme="@style/Theme.ToolsProbe">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>
