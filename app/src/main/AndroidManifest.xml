    <!--
        The agent must be able to see other AppFunction-providing
        packages via `PackageManager.canPackageQuery` so
        `AppFunctionManager.observeAppFunctions` surfaces their metadata. Android 11+
        ships with package visibility on by default; without an explicit `<queries>`
        entry the system filters cross-package metadata out.

        Both shapes are declared:
          - `<intent>` with the system AppFunctionService action makes the agent visible
            to every package that publishes an `@AppFunction`, future-proofing the
            visibility surface for production peers (the agent does not know their
            applicationIds at compile time).
          - The explicit `<package>` for `app.knotwork.android.toolsprobe` is the e2e test's
            target and is kept as a belt-and-suspenders fallback in case the system
            indexer evaluates the explicit form before the intent-filter form.
    -->
    <queries>
        <package android:name="app.knotwork.android.toolsprobe" />
        <intent>
            <action android:name="android.app.appfunctions.AppFunctionService" />
        </intent>
    </queries>

    <application
        android:name=".App"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:enableOnBackInvokedCallback="true"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:largeHeap="true"
        android:networkSecurityConfig="@xml/network_security_config"
        android:theme="@style/Theme.AndroidAIAgent">

        <!-- Firebase Crashlytics / Analytics — auto-collection is disabled
             by default to enforce the opt-in flow. The runtime
             `CrashReportingRepository.setEnabled(true)` flips this on once
             the user accepts the in-app consent dialog; the setting is
             persisted by Firebase across launches until cleared. -->
        <meta-data
            android:name="firebase_crashlytics_collection_enabled"
            android:value="false" />
        <meta-data
            android:name="firebase_analytics_collection_enabled"
            android:value="false" />

        <!-- Required for LiteRT GPU (OpenCL) acceleration -->
        <uses-native-library android:name="libOpenCL.so" android:required="false" />
        <uses-native-library android:name="libvndksupport.so" android:required="false" />
        <!-- Required for LiteRT NPU (Qualcomm DSP) acceleration -->
        <uses-native-library android:name="libcdsprpc.so" android:required="false" />

        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>
        <activity
            android:name=".presentation.ui.MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.App.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
            Callee-side AppFunctions surface is served by the auto-merged
            androidx.appfunctions.service.PlatformAppFunctionService (from
            `appfunctions-service`), enabled on API 36+. Functions are discovered through
            `@AppFunction`-annotated classes (see [SearchAppFunction]); the agent only
            needs to publish them — no hand-rolled `AppFunctionService` subclass.
        -->

        <service
            android:name=".data.services.AgentForegroundService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="On-Device LLM Inference and Agent Orchestration" />
        </service>

        <!--
            WorkManager promotes long-running workers (AgentWorker during scheduled
            inference) through its own SystemForegroundService. Android 14+ requires
            the service entry to declare the foreground type the promotion uses —
            merged here as `specialUse` with the same subtype the app's own
            AgentForegroundService is declared for.
        -->
        <service
            android:name="androidx.work.impl.foreground.SystemForegroundService"
            android:exported="false"
            android:foregroundServiceType="specialUse"
            tools:node="merge">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="On-Device LLM Inference and Agent Orchestration" />
        </service>

        <receiver
            android:name=".presentation.receivers.AgentApprovalReceiver"
            android:exported="false" />
    </application>

</manifest>