    <string name="chat_topbar_title_default">Agent Chat</string>
    <string name="chat_topbar_pipeline_label">Pipeline: %1$s</string>
    <string name="chat_topbar_context_label">Context: %1$d / %2$d</string>
    <string name="chat_topbar_show_all_cd">Show all messages</string>
    <string name="chat_topbar_show_starred_cd">Show only starred</string>

