<?xml version="1.0" encoding="utf-8"?>
<!--
    User-facing strings for the chat feature (`presentation/ui/chat/`).

    Keys follow `chat_<context>_<purpose>` where `<context>` identifies the
    sub-surface (topbar, drawer, menu, dialog, sheet, banner, console,
    clarification, trace, thought, message, input, session, snackbar) and
    `<purpose>` describes the role of the string. Content descriptions for
    icons / clickable affordances carry the `_cd` suffix.
-->
<resources>
