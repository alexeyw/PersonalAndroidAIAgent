<?xml version="1.0" encoding="utf-8"?>
<!--
  License metadata strings are generated by `resValue`
  in `app/build.gradle.kts` and intentionally have no in-app consumer yet —
  they will be wired into a future "About" dialog. Without this `tools:keep`
  declaration the lint `UnusedResources` check (strict mode) would
  flag them as dead resources.
-->
<resources xmlns:tools="http://schemas.android.com/tools"
    tools:keep="@string/license_name,@string/license_url" />
