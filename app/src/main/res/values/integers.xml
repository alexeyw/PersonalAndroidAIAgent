<resources>
    <!--
        Chat screen: how long a transient Snackbar is held on screen before it
        auto-dismisses, in milliseconds.
    -->
    <integer name="chat_snackbar_auto_dismiss_ms">1500</integer>

    <!--
        Clarification card: tick interval of the visible countdown timer, in
        milliseconds. One second matches the human-readable resolution of the
        countdown text ("HH:mm:ss").
    -->
    <integer name="clarification_countdown_interval_ms">1000</integer>
</resources>
