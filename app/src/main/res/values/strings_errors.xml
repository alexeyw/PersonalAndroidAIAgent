<?xml version="1.0" encoding="utf-8"?>
<!--
    Error / failure messages surfaced through Snackbars, inline banners, or
    feedback callbacks across the app.

    Keys follow `errors_<feature>_<purpose>` so error strings stay grouped by
    the surface that emits them while remaining in a single localisation
    file. Generic fallbacks live under `errors_generic_*`.
-->
<resources>
